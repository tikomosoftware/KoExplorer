<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- カラーリソース -->
    <Color x:Key="PrimaryColor">#2196F3</Color>
    <Color x:Key="PrimaryDarkColor">#1976D2</Color>
    <Color x:Key="AccentColor">#FF4081</Color>
    
    <Color x:Key="WindowBackgroundColor">#F5F5F5</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFF</Color>
    <Color x:Key="MenuBackgroundColor">#FAFAFA</Color>
    <Color x:Key="ToolBarBackgroundColor">#FAFAFA</Color>
    <Color x:Key="StatusBarBackgroundColor">#EEEEEE</Color>
    
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="SplitterColor">#BDBDBD</Color>
    
    <Color x:Key="ThumbnailBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ThumbnailBorderColor">#E0E0E0</Color>
    <Color x:Key="ThumbnailSelectedColor">#2196F3</Color>
    
    <Color x:Key="TextPrimaryColor">#212121</Color>
    <Color x:Key="TextSecondaryColor">#757575</Color>
    
    <!-- ブラシリソース -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="{StaticResource MenuBackgroundColor}"/>
    <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="{StaticResource ToolBarBackgroundColor}"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="{StaticResource StatusBarBackgroundColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SplitterBrush" Color="{StaticResource SplitterColor}"/>
    
    <SolidColorBrush x:Key="ThumbnailBackgroundBrush" Color="{StaticResource ThumbnailBackgroundColor}"/>
    <SolidColorBrush x:Key="ThumbnailBorderBrush" Color="{StaticResource ThumbnailBorderColor}"/>
    <SolidColorBrush x:Key="ThumbnailSelectedBrush" Color="{StaticResource ThumbnailSelectedColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource TextSecondaryColor}"/>

</ResourceDictionary>
