<Window x:Class="KoExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:vm="clr-namespace:KoExplorer.ViewModels"
        mc:Ignorable="d"
        Title="KoExplorer v1.0.0" 
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app-icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.InputBindings>
        <!-- キーボードショートカット -->
        <KeyBinding Key="Right" Command="{Binding NextImageCommand}"/>
        <KeyBinding Key="Left" Command="{Binding PreviousImageCommand}"/>
        <KeyBinding Key="N" Command="{Binding NextImageCommand}"/>
        <KeyBinding Key="P" Command="{Binding PreviousImageCommand}"/>
        <KeyBinding Key="Home" Command="{Binding FirstImageCommand}"/>
        <KeyBinding Key="End" Command="{Binding LastImageCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleFullScreenCommand}"/>
        <KeyBinding Key="F" Command="{Binding FitToWindowCommand}"/>
        <KeyBinding Key="W" Command="{Binding FitToWidthCommand}"/>
        <KeyBinding Key="H" Command="{Binding FitToHeightCommand}"/>
        <KeyBinding Key="D1" Command="{Binding ActualSizeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteImageCommand}"/>
        <KeyBinding Key="F3" Command="{Binding ToggleThumbnailPanelCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="C" Command="{Binding CopyImageCommand}"/>
        <KeyBinding Modifiers="Ctrl+Shift" Key="C" Command="{Binding CopyPathCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="E" Command="{Binding OpenInExplorerCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding OpenWithDefaultAppCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="OemPlus" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="OemMinus" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="D0" Command="{Binding ActualSizeCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="F" Command="{Binding FitToWindowCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- メニューバー -->
            <RowDefinition Height="Auto"/>
            <!-- ツールバー -->
            <RowDefinition Height="*"/>
            <!-- メインコンテンツ -->
            <RowDefinition Height="Auto"/>
            <!-- ステータスバー -->
            <RowDefinition Height="Auto"/>
            <!-- デバッグログ（デバッグモードのみ） -->
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0" Background="{DynamicResource MenuBackgroundBrush}">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="フォルダを開く(_O)..." Command="{Binding OpenFolderCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="エクスプローラーで開く(_E)" Command="{Binding OpenInExplorerCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="既定のアプリで開く(_D)" Command="{Binding OpenWithDefaultAppCommand}"/>
                <Separator/>
                <MenuItem Header="コピー(_C)" Command="{Binding CopyImageCommand}" InputGestureText="Ctrl+C"/>
                <MenuItem Header="パスをコピー(_P)" Command="{Binding CopyPathCommand}" InputGestureText="Ctrl+Shift+C"/>
                <Separator/>
                <MenuItem Header="削除(_D)" Command="{Binding DeleteImageCommand}" InputGestureText="Delete"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Command="{Binding ExitCommand}" InputGestureText="Alt+F4"/>
            </MenuItem>

            <MenuItem Header="表示(_V)">
                <MenuItem Header="フルスクリーン(_F)" Command="{Binding ToggleFullScreenCommand}" InputGestureText="F11" IsCheckable="True" IsChecked="{Binding IsFullScreen}"/>
                <Separator/>
                <MenuItem Header="ズーム(_Z)">
                    <MenuItem Header="拡大(_I)" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++"/>
                    <MenuItem Header="縮小(_O)" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-"/>
                    <MenuItem Header="実寸表示(_A)" Command="{Binding ActualSizeCommand}" InputGestureText="Ctrl+0"/>
                    <Separator/>
                    <MenuItem Header="ウィンドウにフィット(_F)" Command="{Binding FitToWindowCommand}" InputGestureText="F"/>
                    <MenuItem Header="幅に合わせる(_W)" Command="{Binding FitToWidthCommand}" InputGestureText="W"/>
                    <MenuItem Header="高さに合わせる(_H)" Command="{Binding FitToHeightCommand}" InputGestureText="H"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="プレビュー(_P)" Command="{Binding TogglePreviewCommand}" IsCheckable="True" IsChecked="{Binding IsPreviewVisible}"/>
                <MenuItem Header="サムネイルパネル(_T)" Command="{Binding ToggleThumbnailPanelCommand}" InputGestureText="F3" IsCheckable="True" IsChecked="{Binding IsThumbnailPanelVisible}"/>
                <MenuItem Header="フォルダツリー(_R)" IsCheckable="True" IsChecked="{Binding IsFolderTreeVisible}"/>
                <Separator/>
                <MenuItem Header="背景色(_B)">
                    <MenuItem Header="白" Command="{Binding SetBackgroundCommand}" CommandParameter="White" IsCheckable="True" IsChecked="{Binding IsBackgroundWhite}"/>
                    <MenuItem Header="グレー" Command="{Binding SetBackgroundCommand}" CommandParameter="Gray" IsCheckable="True" IsChecked="{Binding IsBackgroundGray}"/>
                    <MenuItem Header="黒" Command="{Binding SetBackgroundCommand}" CommandParameter="Black" IsCheckable="True" IsChecked="{Binding IsBackgroundBlack}"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="ナビゲーション(_N)">
                <MenuItem Header="次の画像(_N)" Command="{Binding NextImageCommand}" InputGestureText="→"/>
                <MenuItem Header="前の画像(_P)" Command="{Binding PreviousImageCommand}" InputGestureText="←"/>
                <MenuItem Header="最初の画像(_F)" Command="{Binding FirstImageCommand}" InputGestureText="Home"/>
                <MenuItem Header="最後の画像(_L)" Command="{Binding LastImageCommand}" InputGestureText="End"/>
            </MenuItem>

            <MenuItem Header="並び替え(_S)">
                <MenuItem Header="ファイル名(昇順)(_N)" Command="{Binding SortCommand}" CommandParameter="NameAsc"/>
                <MenuItem Header="ファイル名(降順)(_D)" Command="{Binding SortCommand}" CommandParameter="NameDesc"/>
                <MenuItem Header="更新日時(昇順)(_M)" Command="{Binding SortCommand}" CommandParameter="DateAsc"/>
                <MenuItem Header="更新日時(降順)(_T)" Command="{Binding SortCommand}" CommandParameter="DateDesc"/>
                <MenuItem Header="ファイルサイズ(昇順)(_S)" Command="{Binding SortCommand}" CommandParameter="SizeAsc"/>
                <MenuItem Header="ファイルサイズ(降順)(_Z)" Command="{Binding SortCommand}" CommandParameter="SizeDesc"/>
            </MenuItem>

            <!--
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="設定(_S)..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)..." Command="{Binding AboutCommand}"/>
            </MenuItem>
            -->
        </Menu>

        <!-- ツールバー -->
        <ToolBar Grid.Row="1" Background="{DynamicResource ToolBarBackgroundBrush}" Padding="8,4">
            <Button Click="OpenFolderButton_Click" ToolTip="フォルダを開く" Padding="8,6">
                <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" 
                      Fill="#FFA726" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding PreviousImageCommand}" ToolTip="前の画像 (←)" Padding="8,6">
                <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Button Command="{Binding NextImageCommand}" ToolTip="次の画像 (→)" Padding="8,6">
                <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding ZoomOutCommand}" ToolTip="縮小 (Ctrl+-)" Padding="8,6">
                <Path Data="M19,13H5V11H19V13Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <TextBlock Text="{Binding ZoomPercentage, StringFormat={}{0:F0}%}" 
                       VerticalAlignment="Center" 
                       Margin="8,0" 
                       MinWidth="50" 
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="#424242"/>
            <Button Command="{Binding ZoomInCommand}" ToolTip="拡大 (Ctrl++)" Padding="8,6">
                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Button Command="{Binding FitToWindowCommand}" ToolTip="ウィンドウにフィット (F)" Padding="8,6">
                <Path Data="M9,9V15H15V9M7,3H17A2,2 0 0,1 19,5V19A2,2 0 0,1 17,21H7A2,2 0 0,1 5,19V5A2,2 0 0,1 7,3Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Button Command="{Binding FitToWidthCommand}" ToolTip="幅に合わせる (W)" Padding="8,6">
                <Grid Width="16" Height="16">
                    <Path Data="M3,7 L3,17 M21,7 L21,17" 
                          Stroke="#424242" StrokeThickness="2" Stretch="Uniform"/>
                    <Path Data="M7,12 L17,12 M7,10 L7,14 M17,10 L17,14" 
                          Stroke="#0078D4" StrokeThickness="2" Stretch="Uniform"/>
                </Grid>
            </Button>
            <Button Command="{Binding ActualSizeCommand}" ToolTip="実寸表示 (1)" Padding="8,6">
                <Path Data="M3,3H21V21H3V3M5,5V19H19V5H5M7,7H17V17H7V7Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding ToggleFullScreenCommand}" ToolTip="フルスクリーン (F11)" Padding="8,6">
                <Path Data="M5,5H10V7H7V10H5V5M14,5H19V10H17V7H14V5M17,14H19V19H14V17H17V14M10,17V19H5V14H7V17H10Z" 
                      Fill="#424242" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <!-- プレビュー表示切り替え -->
            <Button Command="{Binding TogglePreviewCommand}" ToolTip="プレビュー表示切り替え" Padding="8,6">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                      Fill="#0078D4" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <!-- 表示モード切り替え -->
            <Button Command="{Binding SwitchToDetailViewCommand}" ToolTip="詳細表示" Padding="8,6">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailViewMode}" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M3,4H21V6H3V4M3,11H21V13H3V11M3,18H21V20H3V18Z" 
                      Fill="#0078D4" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Button Command="{Binding SwitchToThumbnailViewCommand}" ToolTip="サムネイル表示" Padding="8,6">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsThumbnailViewMode}" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M3,11H11V3H3M3,21H11V13H3M13,21H21V13H13M13,3V11H21V3" 
                      Fill="#0078D4" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding DeleteImageCommand}" ToolTip="削除 (Delete)" Padding="8,6">
                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                      Fill="#D32F2F" Stretch="Uniform" Width="16" Height="16"/>
            </Button>
            <Separator Visibility="{Binding IsDebugMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <!-- テスト用ボタン（デバッグモードのみ） -->
            <Button x:Name="TestTreeButton" 
                    Click="TestTreeButton_Click" 
                    ToolTip="テスト: H:\(01)写真データ" 
                    Padding="8,6" 
                    Background="#FFEB3B"
                    Visibility="{Binding IsDebugMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="TEST" FontWeight="Bold" Foreground="#333"/>
            </Button>
        </ToolBar>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- フォルダツリー -->
                <ColumnDefinition Width="Auto"/>
                <!-- スプリッター -->
                <ColumnDefinition Width="*"/>
                <!-- プレビューエリア -->
            </Grid.ColumnDefinitions>

            <!-- フォルダツリー -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" 
                    Width="250"
                    MinWidth="150"
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    Visibility="{Binding IsFolderTreeVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- ヘッダー -->
                    <Border Grid.Row="0" Background="{DynamicResource ToolBarBackgroundBrush}" Padding="10,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="フォルダ" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                    
                    <!-- TreeView -->
                    <TreeView Grid.Row="1"
                              x:Name="FolderTreeView" 
                              ItemsSource="{Binding FolderTree}"
                              SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="5">
                        <TreeView.Resources>
                            <!-- フォルダアイコンのスタイル -->
                            <Style x:Key="FolderIcon" TargetType="TextBlock">
                                <Setter Property="Text" Value="📁"/>
                                <Setter Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFD54F" Offset="0"/>
                                            <GradientStop Color="#FFA726" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="Padding" Value="2"/>
                                <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource FolderIcon}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Name}" Value="クイックアクセス">
                                                        <Setter Property="Text" Value="⭐"/>
                                                        <Setter Property="Foreground" Value="#0078D4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="PC">
                                                        <Setter Property="Text" Value="💻"/>
                                                        <Setter Property="Foreground" Value="#424242"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="マイピクチャ">
                                                        <Setter Property="Text" Value="🖼️"/>
                                                        <Setter Property="Foreground" Value="#0078D4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Name}" Value="デスクトップ">
                                                        <Setter Property="Text" Value="🖥️"/>
                                                        <Setter Property="Foreground" Value="#0078D4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- スプリッター（縦） -->
            <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}"
                          Visibility="{Binding IsFolderTreeVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- プレビューエリアとファイルリスト -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- 詳細表示モード -->
                <DataGrid Grid.Row="0" Grid.RowSpan="3"
                          x:Name="FileDataGrid"
                          ItemsSource="{Binding ThumbnailItems}"
                          SelectedItem="{Binding SelectedThumbnail}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          SelectionMode="Extended"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="24"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          Visibility="{Binding IsDetailViewMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="名前" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5,0">
                                        <TextBlock FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="📄"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                            <Setter Property="Text" Value="📁"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="更新日時" Width="180">
                            <DataGridTextColumn.Binding>
                                <Binding Path="ModifiedDate" StringFormat="{}{0:yyyy/MM/dd HH:mm}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="種類" Width="120">
                            <DataGridTextColumn.Binding>
                                <Binding Path="FilePath" Converter="{StaticResource FileTypeConverter}"/>
                            </DataGridTextColumn.Binding>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                            <Setter Property="Text" Value="ファイル フォルダー"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="サイズ" Width="100">
                            <DataGridTextColumn.Binding>
                                <Binding Path="FileSize" Converter="{StaticResource FileSizeConverter}"/>
                            </DataGridTextColumn.Binding>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                            <Setter Property="Text" Value=""/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- サムネイル表示モード（画像プレビュー + サムネイルパネル） -->
                <Grid Grid.Row="0" Grid.RowSpan="3" 
                      Visibility="{Binding IsThumbnailViewMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <!-- プレビューエリア -->
                    <Border Grid.Row="0" 
                            Background="{Binding PreviewBackground}"
                            ClipToBounds="True"
                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <!-- 画像表示 -->
                            <ScrollViewer x:Name="ImageScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
                                <Image x:Name="PreviewImage"
                                       Source="{Binding CurrentImageSource}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Width="{Binding ImageDisplayWidth}"
                                       Height="{Binding ImageDisplayHeight}"
                                       MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                       MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                                       MouseMove="PreviewImage_MouseMove"
                                       MouseWheel="PreviewImage_MouseWheel"/>
                            </ScrollViewer>

                            <!-- エラー表示 -->
                            <Border Background="#80000000" 
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⚠" FontSize="48" Foreground="Orange" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ErrorMessage}" 
                                              Foreground="White" 
                                              FontSize="16" 
                                              Margin="0,10,0,0"
                                              TextWrapping="Wrap"
                                              MaxWidth="400"
                                              TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 画像情報オーバーレイ -->
                            <Border Background="#80000000" 
                                    VerticalAlignment="Top" 
                                    HorizontalAlignment="Left"
                                    Padding="10"
                                    Margin="10"
                                    CornerRadius="5"
                                    Visibility="{Binding ShowImageInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentImageInfo.FileName}" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentImageInfo.Resolution}" Foreground="White" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding CurrentImageInfo.FileSize}" Foreground="White"/>
                                    <TextBlock Text="{Binding CurrentImageInfo.Format}" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- スプリッター（横） -->
                    <GridSplitter Grid.Row="1"
                                  Height="5" 
                                  HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch"
                                  Background="{DynamicResource SplitterBrush}">
                        <GridSplitter.Visibility>
                            <MultiBinding Converter="{StaticResource BooleanAndToVisibilityConverter}">
                                <Binding Path="IsThumbnailPanelVisible"/>
                                <Binding Path="IsPreviewVisible"/>
                            </MultiBinding>
                        </GridSplitter.Visibility>
                    </GridSplitter>

                    <!-- サムネイルパネル（プレビュー表示時） -->
                    <Border Grid.Row="2" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0,1,0,0"
                            Background="{DynamicResource PanelBackgroundBrush}">
                        <Border.Visibility>
                            <MultiBinding Converter="{StaticResource BooleanAndToVisibilityConverter}">
                                <Binding Path="IsThumbnailPanelVisible"/>
                                <Binding Path="IsPreviewVisible"/>
                            </MultiBinding>
                        </Border.Visibility>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- サムネイルツールバー -->
                            <ToolBar Grid.Row="0" Background="Transparent">
                                <TextBlock Text="サムネイルサイズ:" VerticalAlignment="Center" Margin="5,0"/>
                                <Slider x:Name="ThumbnailSizeSlider" 
                                        Width="100" 
                                        Minimum="64" 
                                        Maximum="256" 
                                        Value="{Binding ThumbnailSize}"
                                        TickFrequency="32"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ThumbnailSize, StringFormat={}{0:F0}px}" 
                                          VerticalAlignment="Center" 
                                          Margin="5,0"/>
                            </ToolBar>

                            <!-- サムネイルリスト -->
                            <ListBox Grid.Row="1" 
                                     x:Name="ThumbnailListBox"
                                     ItemsSource="{Binding ThumbnailItems}"
                                     SelectedItem="{Binding SelectedThumbnail}"
                                     SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MouseDoubleClick="ThumbnailListBox_MouseDoubleClick">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="5" 
                                                Padding="5"
                                                Background="{DynamicResource ThumbnailBackgroundBrush}"
                                                BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <StackPanel Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Image Source="{Binding ThumbnailSource}" 
                                                       Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Stretch="Uniform"/>
                                                <TextBlock Text="{Binding FileName}" 
                                                          TextTrimming="CharacterEllipsis"
                                                          TextAlignment="Center"
                                                          Margin="0,5,0,0"
                                                          ToolTip="{Binding FileName}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- サムネイルパネル（プレビュー非表示時・全画面） -->
                    <Border Grid.Row="0" Grid.RowSpan="3"
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0"
                            Background="{DynamicResource PanelBackgroundBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsThumbnailPanelVisible}" Value="True"/>
                                            <Condition Binding="{Binding IsPreviewVisible}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- サムネイルツールバー -->
                            <ToolBar Grid.Row="0" Background="Transparent">
                                <TextBlock Text="サムネイルサイズ:" VerticalAlignment="Center" Margin="5,0"/>
                                <Slider Width="100" 
                                        Minimum="64" 
                                        Maximum="256" 
                                        Value="{Binding ThumbnailSize}"
                                        TickFrequency="32"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ThumbnailSize, StringFormat={}{0:F0}px}" 
                                          VerticalAlignment="Center" 
                                          Margin="5,0"/>
                            </ToolBar>

                            <!-- サムネイルリスト -->
                            <ListBox Grid.Row="1" 
                                     x:Name="ThumbnailListBox2"
                                     ItemsSource="{Binding ThumbnailItems}"
                                     SelectedItem="{Binding SelectedThumbnail}"
                                     SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MouseDoubleClick="ThumbnailListBox_MouseDoubleClick">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="5" 
                                                Padding="5"
                                                Background="{DynamicResource ThumbnailBackgroundBrush}"
                                                BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <StackPanel Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Image Source="{Binding ThumbnailSource}" 
                                                       Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Stretch="Uniform"/>
                                                <TextBlock Text="{Binding FileName}" 
                                                          TextTrimming="CharacterEllipsis"
                                                          TextAlignment="Center"
                                                          Margin="0,5,0,0"
                                                          ToolTip="{Binding FileName}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- サムネイルパネル（プレビュー非表示時・全画面） -->
                    <Border Grid.Row="0" Grid.RowSpan="3"
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0"
                            Background="{DynamicResource PanelBackgroundBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsThumbnailPanelVisible}" Value="True"/>
                                            <Condition Binding="{Binding IsPreviewVisible}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- サムネイルツールバー -->
                            <ToolBar Grid.Row="0" Background="Transparent">
                                <TextBlock Text="サムネイルサイズ:" VerticalAlignment="Center" Margin="5,0"/>
                                <Slider Width="100" 
                                        Minimum="64" 
                                        Maximum="256" 
                                        Value="{Binding ThumbnailSize}"
                                        TickFrequency="32"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ThumbnailSize, StringFormat={}{0:F0}px}" 
                                          VerticalAlignment="Center" 
                                          Margin="5,0"/>
                            </ToolBar>

                            <!-- サムネイルリスト -->
                            <ListBox Grid.Row="1" 
                                     x:Name="ThumbnailListBox3"
                                     ItemsSource="{Binding ThumbnailItems}"
                                     SelectedItem="{Binding SelectedThumbnail}"
                                     SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MouseDoubleClick="ThumbnailListBox_MouseDoubleClick">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="5" 
                                                Padding="5"
                                                Background="{DynamicResource ThumbnailBackgroundBrush}"
                                                BorderBrush="{DynamicResource ThumbnailBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                            <StackPanel Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Image Source="{Binding ThumbnailSource}" 
                                                       Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                       Stretch="Uniform"/>
                                                <TextBlock Text="{Binding FileName}" 
                                                          TextTrimming="CharacterEllipsis"
                                                          TextAlignment="Center"
                                                          Margin="0,5,0,0"
                                                          ToolTip="{Binding FileName}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <StatusBar Grid.Row="3" Background="{DynamicResource StatusBarBackgroundBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentImageIndex, StringFormat=画像 {0}}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding TotalImages, StringFormat=/ {0}}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentImageInfo.Resolution}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentImageInfo.FileSize}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- デバッグログエリア（デバッグモードのみ） -->
        <Border Grid.Row="4" 
                Height="150"
                Background="#FFF9C4" 
                BorderBrush="#FBC02D" 
                BorderThickness="0,2,0,0"
                Visibility="{Binding IsDebugMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#FBC02D" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🐛 デバッグログ" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                        <Button Content="クリア" Click="ClearDebugLog_Click" Margin="10,0,0,0" Padding="5,2" Background="White"/>
                    </StackPanel>
                </Border>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="DebugLogTextBox" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Padding="5"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
